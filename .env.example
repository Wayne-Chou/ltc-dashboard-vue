# API root — must include /WebAPI/api (no trailing slash)
# Example login URL: https://service.fongai.co/WebAPI/api/dashboard/login
VITE_API_BASE_URL=https://service.fongai.co/WebAPI/api
VITE_GOOGLE_MAPS_API_KEY=

# Set to true to show the group compare mode button in the dashboard header
VITE_ENABLE_COMPARE_MODE=false
